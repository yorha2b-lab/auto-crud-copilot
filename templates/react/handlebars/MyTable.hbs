<MyTable
    {{#if hasPagination}}
    pagination
    {{/if}}
    query={query}
    total={total}
    rowKey={rowKey}
    search={search}
    loading={loading}
    dataSource={dataSource}
    columns={ {{columnsValue}} }
    setDataSource={setDataSource}
    {{#if hasExpandable}}
    {{{{raw}}}}
    expandable={{ onExpand, expandedRowKeys, expandedRowRender, columnWidth: 24 }}
    {{{{/raw}}}}
    {{/if}}
    {{#if hasPagination}}
    {{{{raw}}}}
    onChange={(pagination, filters, sorter) => {
        if (sorter.column) {
            const newSearch = { ...search, pageNo: pagination.current, pageSize: pagination.pageSize, orderBy: sorter.field }
            const params = new URLSearchParams(Object.fromEntries(Object.entries({ ...query, ...newSearch }).filter(([key, value]) => !['', null, undefined].includes(value))))
            window.history.replaceState(null, '', `${window.location.pathname}?${params.toString()}`)
            setSearch(newSearch)
        } else {
            setSearch({ ...search,pageNo: pagination.current, pageSize: pagination.pageSize, orderBy: undefined })
        }
    }}
    {{{{/raw}}}}
    {{/if}}
    {{#if hasRowSelection}}
    {{{{raw}}}}
    rowSelection={{
        selectedRowKeys: selectedRows.map(item => item[rowKey]),
        onChange: (keys, rows) => setSelectedRows(rows)
    }}
    {{{{/raw}}}}
    {{/if}}
/>