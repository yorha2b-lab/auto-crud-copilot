<MyTable
    query={query}
    total={total}
    rowKey={rowKey}
    search={search}
    loading={loading}
    dataSource={dataSource}
    columns={ {{columnsValue}} }
    setDataSource={setDataSource}
    {{#if hasExpandable}}
    {{{{raw}}}}
    expandable={{ onExpand, expandedRowKeys, expandedRowRender, columnWidth: 24 }}
    {{{{/raw}}}}
    {{/if}}
    {{#if hasPagination}}
    {{{{raw}}}}
    onChange={(pagination, filters, sorter) => setSearch({ ...search , pageNo: pagination.current, pageSize: pagination.pageSize, orderBy: sorter.column ? sorter.field : undefined })}
    {{{{/raw}}}}
    {{/if}}
    {{#if hasRowSelection}}
    {{{{raw}}}}
    rowSelection={{
        selectedRowKeys: selectedRows.map(item => item[rowKey]),
        onChange: (keys, rows) => setSelectedRows(rows)
    }}
    {{{{/raw}}}}
    {{/if}}
/>